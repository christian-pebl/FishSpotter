# Database
# Prisma / Postgres (matches Vercel Supabase integration variable names)
# In production, Vercel sets these automatically via the Supabase integration.
# POSTGRES_PRISMA_URL uses PgBouncer (pooled, port 6543) - used at runtime
# POSTGRES_URL_NON_POOLING is the direct connection (port 5432) - used for migrations
# For local dev, both can point to the same direct connection URL.
POSTGRES_PRISMA_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
POSTGRES_URL_NON_POOLING="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-for-production"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://aazxphcrexkggbmmceli.supabase.co"
SUPABASE_URL="https://aazxphcrexkggbmmceli.supabase.co"
SUPABASE_STORAGE_BUCKET="snippets"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# AI tools
ANTHROPIC_API_KEY="your-anthropic-api-key"
# ANTHROPIC_MODEL="claude-sonnet-4-6"  # optional, defaults to claude-sonnet-4-6
GEMINI_API_KEY="your-gemini-api-key"
# GEMINI_MODEL="gemini-3.5-flash"  # optional, defaults to gemini-3.5-flash

# Email (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM_ADDRESS="noreply@fish-spotter.com"
EMAIL_FROM_NAME="FishSpotter"
EMAIL_REPLY_TO="hello@pebl-cic.co.uk"
EMAIL_PREVIEW_CATCHALL="test@fish-spotter.com"

# Cron
CRON_SECRET="your-secure-cron-secret"

# Storage provider (choose r2 or supabase)
STORAGE_PROVIDER="supabase"
# R2_ACCOUNT_ID="your-cloudflare-account-id"  # required when STORAGE_PROVIDER=r2
# R2_ACCESS_KEY_ID="your-r2-access-key-id"  # required when STORAGE_PROVIDER=r2
# R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"  # required when STORAGE_PROVIDER=r2
# R2_BUCKET_NAME="fishspotter-snippets"  # required when STORAGE_PROVIDER=r2
# R2_PUBLIC_URL="https://pub-<hash>.r2.dev"  # required when STORAGE_PROVIDER=r2

# Feature flags
# MCQ_CURATED_PHOTOS_ONLY="1"  # optional, set to 1 to show only curated photos in MCQ tiles

# Site
NEXT_PUBLIC_SITE_URL="https://fish-spotter.vercel.app"
