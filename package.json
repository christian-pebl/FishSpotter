{
  "name": "fish-spotter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:tokens": "eslint --max-warnings 0 src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lh:ci": "lhci autorun",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "bootstrap": "tsx scripts/bootstrap/index.ts",
    "check:codecs": "tsx --env-file=.env.local scripts/check-codecs.ts",
    "db:push": "prisma db push",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:check-apis": "tsx --env-file=.env.local scripts/check-apis.ts",
    "db:backfill": "tsx --env-file=.env.local scripts/backfill-probability.ts",
    "db:refresh-images": "tsx --env-file=.env.local scripts/refresh-images.ts",
    "db:migrate-to-r2": "tsx --env-file=.env.local scripts/migrate-to-r2.ts",
    "db:seed-aliases": "tsx --env-file=.env.local scripts/seed-aliases.ts",
    "db:seed-fish-marks": "tsx --env-file=.env.local scripts/seed-fish-marks.ts",
    "db:seed-invert-marks": "tsx --env-file=.env.local scripts/seed-invert-marks.ts",
    "db:build-galleries": "tsx --env-file=.env.local scripts/build-species-galleries.ts",
    "db:enrich-image-meta": "tsx --env-file=.env.local scripts/enrich-image-meta.ts",
    "db:transcode": "tsx --env-file=.env.local scripts/transcode-to-h264.ts",
    "db:audit-references": "tsx --env-file=.env.local scripts/audit-reference-ids.ts",
    "db:confusion-matrix": "tsx --env-file=.env.local scripts/confusion-matrix.ts",
    "db:backfill-references": "tsx --env-file=.env.local scripts/backfill-references.ts",
    "db:retro-score": "tsx --env-file=.env.local scripts/retro-score-answers.ts",
    "images:assess": "tsx --env-file=.env.local scripts/assess-image-quality.ts",
    "db:purge-bad-photos": "tsx --env-file=.env.local scripts/purge-bad-photos.ts",
    "db:backfill-image-dims": "tsx --env-file=.env.local scripts/backfill-image-dims.ts",
    "measure:prompt": "tsx scripts/measure-prompt.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.2",
    "@react-email/components": "^0.0.30",
    "@supabase/supabase-js": "^2.99.3",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "marked": "^14.1.4",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^3.0.7",
    "resend": "^4.8.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/nextjs": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "prisma": "^6.19.2",
    "storybook": "^8.6.18",
    "tailwindcss": "^3",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
