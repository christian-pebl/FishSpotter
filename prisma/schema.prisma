generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  displayName  String?  // optional display name for leaderboard
  createdAt    DateTime @default(now())
  answers      Answer[]
}

model Snippet {
  id           String   @id @default(cuid())
  externalId   String   @unique // folder name e.g. ALG_SC_11_2024-07-08_...
  videoUrl     String   // path under /media/snippets/
  thumbnailUrl String
  site         String
  deployment   String
  depthM      Float?
  lat          Float?
  lon          Float?
  recordingDatetime String?
  staffAnswer  String   // reference label from metadata
  bboxJson     String?  // JSON string of bbox_data.json bboxes
  createdAt    DateTime @default(now())
  answers      Answer[]
}

model Answer {
  id          String   @id @default(cuid())
  userId      String
  snippetId   String
  chosenOption String  // typed answer submitted by the user
  freeText    String?  // legacy free-text field retained for existing data
  isCorrect   Boolean  // matches snippet.staffAnswer
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet     Snippet  @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
}

enum ProbabilityStatus {
  OK
  INSUFFICIENT_DATA
  ERROR
}

model SpeciesProbability {
  id           String            @id @default(cuid())
  latBucket    Float
  lonBucket    Float
  depthBucket  Int               // floor(depthM / 10) * 10, or -1 for null
  month        Int               // 1..12
  source       String            // "obis"
  status       ProbabilityStatus
  errorMessage String?
  totalRecords Int               @default(0)
  speciesJson  String            @default("[]") // [{ scientificName, count, probability }]
  fetchedAt    DateTime          @default(now())
  staleAfter   DateTime

  @@unique([latBucket, lonBucket, depthBucket, month])
}

model SpeciesNameMap {
  id             String   @id @default(cuid())
  commonName     String   @unique // normalised lowercase
  scientificName String?
  source         String   // e.g. "gbif-match"
  confidence     String?  // EXACT | FUZZY | HIGHERRANK | NONE
  resolvedAt     DateTime @default(now())
}
