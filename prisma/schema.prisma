generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String?
  name                String?
  displayName         String? // optional display name for leaderboard
  emailVerified       DateTime? // set when the user clicks the verification link (S3-06/07)
  onboardedAt         DateTime? // set when the user dismisses the first-run tour (S3-11)
  digestOptIn         Boolean              @default(false) // weekly digest (S3-16); PECR Reg. 22 opt-in
  // ICO Children's Code (UK Age Appropriate Design Code): self-declared age
  // band at signup. We store a coarse BAND, not date of birth, to minimise
  // personal data. Null for pre-existing users (declared at signup only).
  ageBracket          String? // "13_17" | "18_plus" — null for pre-existing users
  // Declared minors (13-17) default to OFF the public leaderboard; any user
  // can change this later in account settings.
  leaderboardOptIn    Boolean              @default(true)
  lastStreakNudgeAt   DateTime? // one streak-nudge per user per week (S3-17)
  createdAt           DateTime             @default(now())
  answers             Answer[]
  unlockedSpecies     UnlockedSpecies[]
  events              Event[]
  accounts            Account[]
  sessions            Session[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

// NextAuth-canonical Account / Session shapes. Scaffolded ahead of any
// OAuth provider (S3-02) so a future ticket can drop GoogleProvider /
// AppleProvider into the providers array with no migration.
// PrismaAdapter is wired in src/lib/auth.ts but session strategy stays
// `jwt` — these tables stay empty until an OAuth provider is added.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Email-verification tokens (S3-06). `token` stores SHA-256 of the
// random secret so a DB leak doesn't hand over active verification
// links. Plain token only ever lives in the outbound email body.
model VerificationToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime // now + 24h
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Password-reset tokens (S3-04). Same hash-at-rest pattern. Shorter TTL
// (1h) because the threat model is different — a stale reset link is a
// privilege-escalation vector, a stale verify link only wastes time.
model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime // now + 1h
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Snippet {
  id                String   @id @default(cuid())
  externalId        String   @unique // folder name e.g. ALG_SC_11_2024-07-08_...
  videoUrl          String // path under /media/snippets/
  thumbnailUrl      String
  site              String
  deployment        String
  depthM            Float?
  lat               Float?
  lon               Float?
  recordingDatetime String?
  staffAnswer       String? // reference label from metadata; null = no reference yet (S7-T1)
  bboxJson          String? // JSON string of bbox_data.json bboxes (auto track: RT-DETR/motion)
  manualTrackJson   String? // JSON string of manual_track.points (hand-marked centre path); preferred over bboxJson when set
  createdAt         DateTime @default(now())
  answers           Answer[]

  // S4-06: indexes for archive filter / sort / search.
  @@index([createdAt])
  @@index([site])
  @@index([staffAnswer])
}

model Answer {
  id           String   @id @default(cuid())
  userId       String
  snippetId    String
  chosenOption String // typed answer submitted by the user
  freeText     String? // legacy free-text field retained for existing data
  isCorrect    Boolean? // matches snippet.staffAnswer; null = snippet has no reference yet (S7-T1)
  points       Int      @default(0) // scoring: correct=2, pending=1, incorrect=0; sumed for leaderboard (S7-T1)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet      Snippet  @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  // S4-01: indexes for the leaderboard groupBy + timeframe filter
  // (S4-03). The covering compound indexes prevent sequential scans
  // on the Answer table as it grows past ~50k rows.
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([isCorrect, createdAt])
}

enum ProbabilityStatus {
  OK
  INSUFFICIENT_DATA
  ERROR
}

model SpeciesProbability {
  id           String            @id @default(cuid())
  latBucket    Float
  lonBucket    Float
  depthBucket  Int // floor(depthM / 10) * 10, or -1 for null
  month        Int // 1..12
  source       String // "obis"
  status       ProbabilityStatus
  errorMessage String?
  totalRecords Int               @default(0)
  speciesJson  String            @default("[]") // [{ scientificName, count, probability }]
  fetchedAt    DateTime          @default(now())
  staleAfter   DateTime

  @@unique([latBucket, lonBucket, depthBucket, month])
}

model SpeciesNameMap {
  id             String   @id @default(cuid())
  commonName     String   @unique // normalised lowercase
  scientificName String?
  source         String // e.g. "gbif-match"
  confidence     String? // EXACT | FUZZY | HIGHERRANK | NONE
  resolvedAt     DateTime @default(now())
}

// Accepted alternative names for each catalogued species. The chat / quiz
// engine treats the user's answer as correct if it normalises to either the
// canonical scientific name or any of the listed aliases. Seeded from
// src/data/species-aliases.json plus auto-resolved scientific names from
// SpeciesNameMap (see scripts/seed-aliases.ts).
//
// Lookup is by NORMALIZED key (lowercase, diacritic-stripped, etc.) so a
// staffAnswer of "Pollack", "pollack", or "Pollachius pollachius" all resolve
// to the same row.
model SpeciesAlias {
  id            String   @id @default(cuid())
  canonical     String   @unique // e.g. "Pollachius pollachius" (display form)
  normalizedKey String   @unique // normalised form of canonical for lookup
  aliases       String[] // acceptable surface forms; normalised at compare time
  updatedAt     DateTime @updatedAt
}

model SpeciesImage {
  id              String           @id @default(cuid())
  scientificName  String
  lifeStage       String? // "adult" | "juvenile" | "larva" | "egg" | null
  sex             String? // "male" | "female" | null
  url             String // medium-quality direct image URL (iNat/Wikimedia origin)
  thumbUrl        String? // smaller cached URL if the source provides one
  // Route C: PEBL-hosted WebP derivatives (R2/Supabase via scripts/lib/storage.ts),
  // transcoded from `url` by the transcode batch (scripts/backfill-webp-images.ts +
  // /api/cron/transcode-images). Nullable = "not yet transcoded". Consumers prefer
  // these over url/thumbUrl and fall back to the origin when null, so the feature
  // degrades gracefully if a transcode fails or hasn't run. ~30-50% smaller than the
  // source JPEG and served from our own edge (no transatlantic iNat-S3 hop).
  webpUrl         String? // medium WebP (<=500px), our host
  webpThumbUrl    String? // thumb WebP (<=240px), our host
  attribution     String // formatted "(c) Username, CC BY"
  sourceUrl       String // link back to the original observation / file page
  license         String // "cc0" | "cc-by" | "cc-by-sa" | "cc-by-nc" | "cc-by-nc-sa" | ...
  source          String // "inaturalist" | "wikimedia" | "manual"
  width           Int?
  height          Int?
  observedOn      String? // date (or year) the source photo was observed, if known
  placeGuess      String? // human-readable location of the source observation, if known
  ordering        Int              @default(100) // lower = earlier in the gallery
  curated         Boolean          @default(false) // true when set via manifest, not script
  createdAt       DateTime         @default(now())
  refreshedAt     DateTime         @default(now())
  diagnosticMarks DiagnosticMark[]

  @@unique([scientificName, sourceUrl])
  @@index([scientificName, ordering])
}

// Admin-authored diagnostic features for the "Help me identify" wizard.
// Each row is one "look-for-this" pointer on a reference photo:
// e.g. for Trisopterus luscus (bib), a mark labelled "Chin barbel"
// circling the underside of the jaw. The wizard renders these as labelled
// rings overlaid on the chosen photo in the final reveal.
//
// Authoring happens at /admin/species/[scientificName] (admins only,
// gated on @pebl-cic.co.uk email suffix). The data is intentionally
// DB-backed rather than JSON so experts can edit without a code deploy.
//
// Coordinates are normalised to the photo's intrinsic dimensions
// (0..1 on each axis) so the overlay survives resizing / cropping.
// A species is treated as "published" by the wizard once it has >=1
// mark, so no separate status flag is needed.
model DiagnosticMark {
  id             String       @id @default(cuid())
  scientificName String // matches SpeciesImage.scientificName + species-traits.json keys
  speciesImageId String // the photo this mark annotates
  order          Int          @default(0) // display order, low first
  label          String // short title, e.g. "Chin barbel"
  description    String // one-sentence explanation
  overlayX       Float // 0..1, normalised x of the ring centre
  overlayY       Float // 0..1, normalised y of the ring centre
  overlayRadius  Float // 0..1, normalised radius (as fraction of min(width,height))
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String? // email of the admin who authored it (audit trail)
  speciesImage   SpeciesImage @relation(fields: [speciesImageId], references: [id], onDelete: Cascade)

  @@index([scientificName, order])
  @@index([speciesImageId])
}

// Q3A-T8 (S7-T1 phase 2): when 3+ distinct users converge on the same
// normalised name for a no-reference snippet, a daily cron retro-credits
// each matching Answer.points with POINTS_CONSENSUS_BONUS (+2). One row
// per (snippetId, normalisedName) pair; `creditedAnswerIds` tracks which
// Answer rows have already received the bonus so re-runs are no-ops and
// late-joiners get retro-credited on subsequent runs.
model ConsensusEvent {
  id                String   @id @default(cuid())
  snippetId         String // FK target: Snippet.id (no relation field; Snippet doesn't need the back-pointer)
  normalisedName    String // normalizeForMatch(chosenOption) value the consensus is on
  achievedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt
  creditedAnswerIds String[] // Answer.id rows already credited the +2 bonus

  @@unique([snippetId, normalisedName])
  @@index([snippetId])
}

// Pokedex: one row per species a user has correctly identified at least once.
// A correct Answer (isCorrect = true) whose reference resolves to a catalogue
// species upserts a row here (see src/app/api/answers/route.ts). The collection
// grid greys out species without a row. firstUnlockedAt powers "newest catch".
model UnlockedSpecies {
  id              String   @id @default(cuid())
  userId          String
  scientificName  String // catalogue binomial (key into species-traits.json)
  firstUnlockedAt DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scientificName])
  @@index([userId])
}

// Read-through caches for the species profile's OBIS-derived sections, so a
// profile render doesn't re-hit OBIS (a cold render is ~15s). Keyed by the
// catalogue binomial; refreshed when staleAfter passes (see species-cache.ts).
// summaryJson/gridJson may be null = "checked, OBIS had no usable data".
model SpeciesDepthCache {
  scientificName String   @id
  summaryJson    String? // serialized DepthSummary | null
  fetchedAt      DateTime @default(now())
  staleAfter     DateTime
}

model SpeciesDistributionCache {
  scientificName String   @id
  gridJson       String? // serialized DistributionGrid | null
  fetchedAt      DateTime @default(now())
  staleAfter     DateTime
}

// Web-vitals sink (S4-16). One row per LCP / CLS / INP sample beaconed
// from WebVitalsReporter to POST /api/vitals (10% of sessions). `rating`
// is nullable because the current client payload does not send it yet
// (forward-compatible with web-vitals' good/needs-improvement/poor bucket).
model Vital {
  id        String   @id @default(cuid())
  name      String // metric name: "LCP" | "CLS" | "INP"
  value     Float
  rating    String? // "good" | "needs-improvement" | "poor", if known
  path      String? // window.location.pathname at report time
  ua        String? // truncated user-agent string
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}

// Engagement event log — Climate Action Fund impact measurement (first-party,
// privacy-first). We deliberately store the MINIMUM: no IP, no user-agent, no
// referrer, no persistent cross-visit device id. It captures only what can't be
// derived from the Answer / UnlockedSpecies tables — sessions, active
// watch-time, and clip views — so identifications, accuracy and species-learned
// stay derived, not duplicated.
//
// `sessionId` is a random per-TAB id (sessionStorage), so nothing follows a
// person across visits; `userId` links events to an account only while signed
// in. Every write is gated on analytics consent (see POST /api/events). Rows are
// an append-only stream; the admin dashboard aggregates them on demand.
model Event {
  id        String   @id @default(cuid())
  userId    String? // null for signed-out spotters; set when authed
  sessionId String // random per-tab id, NOT a cross-visit fingerprint
  type      String // "session_start" | "clip_view" | "clip_watch"
  snippetId String? // the clip this event is about, when relevant
  value     Float? // generic numeric payload (clip_watch: active seconds)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type, createdAt])
  @@index([userId, createdAt])
}
