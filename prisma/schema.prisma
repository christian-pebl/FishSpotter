generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  passwordHash        String?
  name                String?
  displayName         String?             // optional display name for leaderboard
  emailVerified       DateTime?           // set when the user clicks the verification link (S3-06/07)
  onboardedAt         DateTime?           // set when the user dismisses the first-run tour (S3-11)
  digestOptIn         Boolean             @default(false) // weekly digest (S3-16); PECR Reg. 22 opt-in
  lastStreakNudgeAt   DateTime?           // one streak-nudge per user per week (S3-17)
  createdAt           DateTime            @default(now())
  answers             Answer[]
  accounts            Account[]
  sessions            Session[]
  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
}

// NextAuth-canonical Account / Session shapes. Scaffolded ahead of any
// OAuth provider (S3-02) so a future ticket can drop GoogleProvider /
// AppleProvider into the providers array with no migration.
// PrismaAdapter is wired in src/lib/auth.ts but session strategy stays
// `jwt` — these tables stay empty until an OAuth provider is added.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Email-verification tokens (S3-06). `token` stores SHA-256 of the
// random secret so a DB leak doesn't hand over active verification
// links. Plain token only ever lives in the outbound email body.
model VerificationToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime  // now + 24h
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Password-reset tokens (S3-04). Same hash-at-rest pattern. Shorter TTL
// (1h) because the threat model is different — a stale reset link is a
// privilege-escalation vector, a stale verify link only wastes time.
model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  expiresAt  DateTime  // now + 1h
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Snippet {
  id           String   @id @default(cuid())
  externalId   String   @unique // folder name e.g. ALG_SC_11_2024-07-08_...
  videoUrl     String   // path under /media/snippets/
  thumbnailUrl String
  site         String
  deployment   String
  depthM      Float?
  lat          Float?
  lon          Float?
  recordingDatetime String?
  staffAnswer  String?  // reference label from metadata; null = no reference yet (S7-T1)
  bboxJson     String?  // JSON string of bbox_data.json bboxes
  createdAt    DateTime @default(now())
  answers      Answer[]

  // S4-06: indexes for archive filter / sort / search.
  @@index([createdAt])
  @@index([site])
  @@index([staffAnswer])
}

model Answer {
  id          String   @id @default(cuid())
  userId      String
  snippetId   String
  chosenOption String  // typed answer submitted by the user
  freeText    String?  // legacy free-text field retained for existing data
  isCorrect   Boolean? // matches snippet.staffAnswer; null = snippet has no reference yet (S7-T1)
  points      Int      @default(0) // scoring: correct=2, pending=1, incorrect=0; sumed for leaderboard (S7-T1)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet     Snippet  @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])

  // S4-01: indexes for the leaderboard groupBy + timeframe filter
  // (S4-03). The covering compound indexes prevent sequential scans
  // on the Answer table as it grows past ~50k rows.
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([isCorrect, createdAt])
}

enum ProbabilityStatus {
  OK
  INSUFFICIENT_DATA
  ERROR
}

model SpeciesProbability {
  id           String            @id @default(cuid())
  latBucket    Float
  lonBucket    Float
  depthBucket  Int               // floor(depthM / 10) * 10, or -1 for null
  month        Int               // 1..12
  source       String            // "obis"
  status       ProbabilityStatus
  errorMessage String?
  totalRecords Int               @default(0)
  speciesJson  String            @default("[]") // [{ scientificName, count, probability }]
  fetchedAt    DateTime          @default(now())
  staleAfter   DateTime

  @@unique([latBucket, lonBucket, depthBucket, month])
}

model SpeciesNameMap {
  id             String   @id @default(cuid())
  commonName     String   @unique // normalised lowercase
  scientificName String?
  source         String   // e.g. "gbif-match"
  confidence     String?  // EXACT | FUZZY | HIGHERRANK | NONE
  resolvedAt     DateTime @default(now())
}

// Accepted alternative names for each catalogued species. The chat / quiz
// engine treats the user's answer as correct if it normalises to either the
// canonical scientific name or any of the listed aliases. Seeded from
// src/data/species-aliases.json plus auto-resolved scientific names from
// SpeciesNameMap (see scripts/seed-aliases.ts).
//
// Lookup is by NORMALIZED key (lowercase, diacritic-stripped, etc.) so a
// staffAnswer of "Pollack", "pollack", or "Pollachius pollachius" all resolve
// to the same row.
model SpeciesAlias {
  id            String   @id @default(cuid())
  canonical     String   @unique // e.g. "Pollachius pollachius" (display form)
  normalizedKey String   @unique // normalised form of canonical for lookup
  aliases       String[] // acceptable surface forms; normalised at compare time
  updatedAt     DateTime @updatedAt
}

model SpeciesImage {
  id             String   @id @default(cuid())
  scientificName String
  lifeStage      String?  // "adult" | "juvenile" | "larva" | "egg" | null
  sex            String?  // "male" | "female" | null
  url            String   // medium-quality direct image URL
  thumbUrl       String?  // smaller cached URL if the source provides one
  attribution    String   // formatted "(c) Username, CC BY"
  sourceUrl      String   // link back to the original observation / file page
  license        String   // "cc0" | "cc-by" | "cc-by-sa" | "cc-by-nc" | "cc-by-nc-sa" | ...
  source         String   // "inaturalist" | "wikimedia" | "manual"
  width          Int?
  height         Int?
  ordering       Int      @default(100) // lower = earlier in the gallery
  curated        Boolean  @default(false) // true when set via manifest, not script
  createdAt      DateTime @default(now())
  refreshedAt    DateTime @default(now())
  diagnosticMarks DiagnosticMark[]

  @@index([scientificName, ordering])
  @@unique([scientificName, sourceUrl])
}

// Admin-authored diagnostic features for the "Help me identify" wizard.
// Each row is one "look-for-this" pointer on a reference photo:
// e.g. for Trisopterus luscus (bib), a mark labelled "Chin barbel"
// circling the underside of the jaw. The wizard renders these as labelled
// rings overlaid on the chosen photo in the final reveal.
//
// Authoring happens at /admin/species/[scientificName] (admins only,
// gated on @pebl-cic.co.uk email suffix). The data is intentionally
// DB-backed rather than JSON so experts can edit without a code deploy.
//
// Coordinates are normalised to the photo's intrinsic dimensions
// (0..1 on each axis) so the overlay survives resizing / cropping.
// A species is treated as "published" by the wizard once it has >=1
// mark, so no separate status flag is needed.
model DiagnosticMark {
  id             String   @id @default(cuid())
  scientificName String   // matches SpeciesImage.scientificName + species-traits.json keys
  speciesImageId String   // the photo this mark annotates
  order          Int      @default(0)   // display order, low first
  label          String   // short title, e.g. "Chin barbel"
  description    String   // one-sentence explanation
  overlayX       Float    // 0..1, normalised x of the ring centre
  overlayY       Float    // 0..1, normalised y of the ring centre
  overlayRadius  Float    // 0..1, normalised radius (as fraction of min(width,height))
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?  // email of the admin who authored it (audit trail)
  speciesImage   SpeciesImage @relation(fields: [speciesImageId], references: [id], onDelete: Cascade)

  @@index([scientificName, order])
  @@index([speciesImageId])
}
